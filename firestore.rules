rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity-specific Validators
    function isValidUserProfile(data) {
      return data.userId == request.auth.uid
        && data.displayName is string
        && data.displayName.size() <= 100
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidMockupHistory(data) {
      return data.userId == request.auth.uid
        && data.id is string
        && data.id.size() <= 128
        && data.medium is string
        && data.medium in ['mug', 'billboard', 'tshirt', 'phone_case', 'totebag']
        && data.originalImage is string
        && data.originalImage.size() <= 10000000
        && data.mockupImage is string
        && data.mockupImage.size() <= 10000000
        && (!('prompt' in data) || (data.prompt is string && data.prompt.size() <= 5000))
        && (!('productName' in data) || (data.productName is string && data.productName.size() <= 200))
        && (!('productDescription' in data) || (data.productDescription is string && data.productDescription.size() <= 1000));
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == existing().createdAt
        && (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']));
      allow delete: if false;

      // Nested Collection: Mockups
      match /mockups/{mockupId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidId(mockupId)
          && isValidMockupHistory(incoming())
          && incoming().createdAt == request.time;
        allow update: if false; // Mockup history is immutable after creation
        allow delete: if isOwner(userId);
      }
    }
  }
}
